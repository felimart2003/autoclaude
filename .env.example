# Copy this file to .env and fill in the token.

# Required: Notion internal integration secret.
# 1. Go to https://www.notion.so/profile/integrations  ->  New integration (internal).
# 2. Copy the secret (starts with ntn_).
# 3. Open the "Claude Projects" database in Notion -> ... menu -> Connections -> add your integration.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

